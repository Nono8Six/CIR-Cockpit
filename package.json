{
  "name": "cir-cockpit-workspace",
  "private": true,
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "scripts": {
    "prepare": "husky",
    "repo:check": "node ./scripts/check-repo-state.mjs",
    "typecheck": "pnpm run frontend:typecheck && pnpm run backend:typecheck",
    "lint": "pnpm run frontend:lint && pnpm run backend:lint",
    "test": "pnpm run frontend:test && pnpm run backend:test",
    "build": "pnpm run frontend:build",
    "frontend:typecheck": "pnpm --dir frontend run typecheck",
    "frontend:lint": "pnpm --dir frontend run lint",
    "frontend:test": "pnpm --dir frontend run test:run",
    "frontend:error-compliance": "pnpm --dir frontend run check:error-compliance",
    "frontend:build": "pnpm --dir frontend run build",
    "backend:lint": "deno lint backend/functions/api",
    "backend:typecheck": "deno check --config backend/deno.json backend/functions/api/index.ts",
    "backend:test": "deno test --env-file=backend/.env --allow-env --no-check --config backend/deno.json backend/functions/api",
    "backend:test:integration": "node ./scripts/run-backend-integration-tests.mjs",
    "qa:fast": "pnpm run repo:check && pnpm --dir frontend run typecheck && pnpm --dir frontend run lint && pnpm --dir frontend run test:run && pnpm --dir frontend run check:error-compliance && deno lint backend/functions/api && deno check --config backend/deno.json backend/functions/api/index.ts && deno test --env-file=backend/.env --allow-env --no-check --config backend/deno.json backend/functions/api",
    "qa": "pwsh -NoLogo -File scripts/qa-gate.ps1",
    "qa:audit": "pnpm --dir frontend exec pnpm audit --audit-level=high"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2"
  },
  "pnpm": {
    "overrides": {
      "ajv": "6.14.0",
      "rollup": "4.59.0",
      "flatted": "3.4.0",
      "eslint>minimatch": "3.1.4",
      "eslint-plugin-jsx-a11y>minimatch": "3.1.4",
      "eslint-plugin-react>minimatch": "3.1.4",
      "@typescript-eslint/typescript-estree>minimatch": "9.0.7"
    }
  },
  "lint-staged": {
    "frontend/src/**/*.{ts,tsx}": [
      "pnpm --dir frontend exec eslint --max-warnings=0"
    ],
    "shared/**/*.ts": [
      "pnpm --dir frontend exec eslint --max-warnings=0 --no-warn-ignored"
    ],
    "backend/functions/api/**/*.ts": [
      "deno lint"
    ]
  }
}
