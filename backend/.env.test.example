# Active explicitement les tests d'integration reseau.
RUN_API_INTEGRATION=0

# Projet Supabase cible.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Comptes de test dedies.
API_INT_ADMIN_EMAIL=admin@example.test
API_INT_ADMIN_PASSWORD=change-me
API_INT_USER_EMAIL=user@example.test
API_INT_USER_PASSWORD=change-me

# Origine CORS optionnelle pour les probes auth.
API_INT_ORIGIN=http://localhost:3000
